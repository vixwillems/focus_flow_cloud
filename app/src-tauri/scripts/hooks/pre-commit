#!/usr/bin/env bash
# Pre-commit hook: fail the commit if Info.plist or the entitlements
# file under app/src-tauri/gen/apple/ have drifted from what
# `xcodegen generate` would produce from project.yml.
#
# Only runs when a file under app/src-tauri/gen/apple/ is staged, so
# non-iOS commits pay zero overhead. Bypass with `git commit
# --no-verify` (e.g. if the regen infra is temporarily broken and
# you need to land a fix).
#
# Source of truth and full regen contract: see
# app/src-tauri/gen/apple/project.yml (the file-level comment at
# the top) and AGENTS.md, "iOS project: project.yml is the source
# of truth".

set -euo pipefail

# Only run the check if at least one iOS project file is staged.
# `git diff --cached --name-only` lists the staged files; we filter
# to anything under the iOS gen directory.
staged_ios_files=$(git diff --cached --name-only -- 'app/src-tauri/gen/apple/')
if [ -z "$staged_ios_files" ]; then
    exit 0
fi

# Run the check via `just` so it picks up the user's just install.
# Falls back to running the script directly if `just` isn't on PATH
# (e.g. CI without the just binary).
if command -v just >/dev/null 2>&1; then
    just check-ios
else
    bash app/src-tauri/scripts/check_ios_regen.sh
fi
