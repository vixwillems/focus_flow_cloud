{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FocusFlow",
  "version": "1.1.0",
  "identifier": "com.francescopio.focusflow",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "FocusFlow",
        "width": 1024,
        "height": 768,
        "minWidth": 400,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "88QN5KYG2G"
    },
    "macOS": {
      "infoPlist": "./Info.plist"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
